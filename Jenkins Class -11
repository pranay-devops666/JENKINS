pipeline script to e-mail notification like below
=====================================================

post {
    success {
      mail to: 'gorantlapranay8@gmail.com',
           subject: "SUCCESS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
           body: "Good news — build succeeded!\n${env.BUILD_URL}"
    }
    failure {
      mail to: 'gorantlapranay8@gmail.com',
           subject: "PIPELINE STATUS: ${env.JOB_NAME} #${env.BUILD_NUMBER}",
           body: "*${currentBuild.current Result}: * Job ${env.JOB_NAME} \n build ${env.BUILD_NUMBER} \n more info at: ${env.BUILD_URL}"
    }
  }


